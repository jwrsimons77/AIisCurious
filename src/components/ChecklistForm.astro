---
/**
 * Lower-commitment lead capture: email only, in exchange for an instant PDF
 * download. Uses a separate Netlify Forms form ("checklist") from the main
 * booking form, so the two lead types don't mix in notifications/exports.
 */
---

<form
  class="checklist-form"
  name="checklist"
  method="POST"
  action="/ai-readiness-checklist/thanks/"
  data-netlify="true"
  netlify-honeypot="bot-field"
  data-checklist-form
  novalidate
>
  <input type="hidden" name="form-name" value="checklist" />
  <input type="hidden" name="utm_source" data-attr="utm_source" />
  <input type="hidden" name="utm_medium" data-attr="utm_medium" />
  <input type="hidden" name="utm_campaign" data-attr="utm_campaign" />
  <input type="hidden" name="landing_page" data-attr="landing_page" />

  <div class="field">
    <label for="cf-email">Email address</label>
    <input id="cf-email" name="email" type="email" autocomplete="email" required />
  </div>

  <p class="hp" aria-hidden="true">
    <label>Leave this field empty <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </p>

  <button type="submit" class="btn btn--primary btn--lg form-submit">Send me the checklist</button>
  <p class="form-reassure">One email, one PDF. No newsletter, no spam — you can unsubscribe from anything you're never signed up to.</p>

  <p class="form-status" role="status" aria-live="polite" data-form-status hidden></p>
</form>

<style>
  .checklist-form {
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 1.2rem + 2vw, 2.5rem);
    box-shadow: var(--shadow-sm);
  }

  .field {
    display: grid;
    gap: 0.4rem;
  }

  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-submit {
    width: 100%;
    margin-top: 1.25rem;
  }

  .form-reassure {
    margin-top: 0.85rem;
    font-size: var(--text-xs);
    color: var(--muted);
    text-align: center;
  }

  .form-status {
    margin-top: 1rem;
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    color: var(--accent-ink);
    font-weight: 500;
    text-align: center;
  }

  .form-status[data-state='error'] {
    background: var(--amber-soft);
    color: var(--ink);
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-checklist-form]');
  const status = document.querySelector<HTMLElement>('[data-form-status]');

  try {
    const attribution = JSON.parse(localStorage.getItem('lead-attribution') ?? '{}');
    form?.querySelectorAll<HTMLInputElement>('[data-attr]').forEach((input) => {
      const key = input.dataset.attr!;
      if (attribution[key]) input.value = attribution[key];
    });
  } catch {
    // Malformed or absent attribution data — leave the hidden fields empty.
  }

  form?.addEventListener('submit', async (event) => {
    if (!form.checkValidity()) {
      form.reportValidity();
      event.preventDefault();
      return;
    }

    event.preventDefault();
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (button) {
      button.disabled = true;
      button.textContent = 'Sending…';
    }

    try {
      const data = new FormData(form);
      const body = new URLSearchParams(data as unknown as Record<string, string>).toString();
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      });
      if (!res.ok) throw new Error(`Request failed: ${res.status}`);
      window.location.assign('/ai-readiness-checklist/thanks/');
      return;
    } catch {
      if (status) {
        status.hidden = false;
        status.dataset.state = 'error';
        status.textContent =
          'Something went wrong sending the form. You can download the checklist directly instead:';
        const link = document.createElement('a');
        link.href = '/ai-readiness-checklist.pdf';
        link.textContent = 'Download the AI Readiness Checklist (PDF)';
        link.download = '';
        status.append(document.createElement('br'), link);
      }
    } finally {
      if (button) {
        button.disabled = false;
        button.textContent = 'Send me the checklist';
      }
    }
  });
</script>
