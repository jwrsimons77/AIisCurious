---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import { siteFaqs } from '../data/faqs';
---

<Base
  title="FAQ - Honest Answers About AI for Small Businesses | AIisCurious"
  description="Is AI suitable for my business? Is it secure? What about GDPR? How much does it cost? Honest, plain-English answers to the questions small business owners actually ask."
>
  <PageHero
    eyebrow="FAQ"
    title="Honest answers to real questions"
    lede="These are the questions business owners actually ask me, including the awkward ones about cost, security and whether any of this is worth it. If yours isn’t here, just ask."
    crumbs={[{ label: 'FAQ' }]}
  />

  <section class="section--sm">
    <div class="container container--narrow">
      <FAQ items={siteFaqs} />
    </div>
  </section>

  <CTASection
    heading="Got a question that isn’t here?"
    text="Ask it on a free 15-minute call, or just email. Either way you’ll get a straight answer, not a sales pitch."
  />
</Base>
