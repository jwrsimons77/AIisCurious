---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';
---

<Base
  title="Your Checklist Is Ready | AIisCurious"
  description="Your AI Readiness Checklist download is ready."
  noindex={true}
>
  <section class="thanks">
    <div class="container container--narrow">
      <span class="thanks-check" aria-hidden="true">
        <svg
          width="26"
          height="26"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg
        >
      </span>
      <h1>Your checklist is ready</h1>
      <p class="thanks-lede">Your download should start automatically. If it doesn't, use the button below.</p>

      <a href="/ai-readiness-checklist.pdf" download class="btn btn--primary btn--lg thanks-download">
        Download the AI Readiness Checklist (PDF)
      </a>

      <div class="thanks-meanwhile">
        <h2>Want to go further?</h2>
        <p>
          The checklist is general, on purpose. If you'd like a personalised view of where AI
          could save your specific business time,
          <a href={site.bookingUrl}>book a free 15-minute call</a> and you'll get a written AI
          Opportunity Report to go with it.
        </p>
      </div>
    </div>
  </section>
</Base>

<!--
  Triggers the PDF download automatically and fires lead conversion events —
  only if the visitor consented to tracking (see ConsentPixel.astro).
-->
<script>
  const link = document.querySelector<HTMLAnchorElement>('.thanks-download');
  if (link) {
    const auto = document.createElement('a');
    auto.href = link.href;
    auto.download = '';
    document.body.appendChild(auto);
    auto.click();
    auto.remove();
  }

  const fireConversions = () => {
    const w = window as any;
    w.fbq?.('track', 'Lead', { content_name: 'ai-readiness-checklist' });
    w.gtag?.('event', 'generate_lead', { lead_type: 'checklist_download' });
  };
  if ((window as any).fbq || (window as any).gtag) fireConversions();
  else document.addEventListener('tracking:ready', fireConversions, { once: true });
</script>

<style>
  .thanks {
    padding-block: clamp(3.5rem, 2.5rem + 5vw, 7rem);
  }

  .thanks-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    margin-bottom: 1.5rem;
  }

  :global(:root[data-theme='dark']) .thanks-check {
    color: #10201c;
  }

  .thanks-lede {
    margin-top: 1rem;
    font-size: var(--text-lg);
    color: var(--muted);
  }

  .thanks-download {
    margin-top: 2rem;
  }

  .thanks-meanwhile {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line-soft);
  }

  .thanks-meanwhile h2 {
    font-size: var(--text-lg);
    margin-bottom: 0.5rem;
  }

  .thanks-meanwhile p {
    color: var(--muted);
  }
</style>
