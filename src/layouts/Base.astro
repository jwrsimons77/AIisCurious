---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';
import ConsentPixel from '../components/ConsentPixel.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  /** Extra JSON-LD objects rendered alongside the LocalBusiness schema */
  schema?: Record<string, unknown>[];
  ogType?: 'website' | 'article';
  /** Absolute URL of a page-specific social sharing image */
  ogImage?: string;
  noindex?: boolean;
  /** Landing-page mode: no nav, no footer links, no sticky CTA */
  minimal?: boolean;
}

const {
  title,
  description,
  schema = [],
  ogType = 'website',
  ogImage = new URL('/og-default.png', site.url).href,
  noindex = false,
  minimal = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url).href;

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${site.url}/#business`,
  name: site.name,
  description: site.tagline,
  url: site.url,
  email: site.email,
  founder: {
    '@type': 'Person',
    name: site.founder,
    jobTitle: 'Independent AI Consultant',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  areaServed: [
    'Manchester',
    'Greater Manchester',
    'Liverpool',
    'Merseyside',
    'Cheshire',
    'Lancashire',
    'Cumbria',
    'North West England',
  ].map((name) => ({ '@type': 'Place', name })),
  priceRange: '££',
  knowsAbout: [
    'Artificial Intelligence',
    'AI implementation',
    'Workflow automation',
    'AI training',
    'ChatGPT',
    'Claude',
    'Microsoft Copilot',
  ],
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  name: site.name,
  url: site.url,
  description: site.tagline,
  publisher: { '@id': `${site.url}/#business` },
  inLanguage: 'en-GB',
};

const allSchema = [localBusiness, website, ...schema];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} blog`} href="/rss.xml" />
    <meta name="theme-color" content="#fbfaf7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#14130f" media="(prefers-color-scheme: dark)" />

    <!-- OpenGraph -->
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(allSchema)} />

    <!-- Theme initialisation: runs before paint to avoid a flash -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const preferred =
          stored ?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = preferred;
      })();
    </script>

    <!--
      Lead attribution: capture UTM/click params on landing, keep the
      first-touch values in localStorage so the booking form can tag each
      lead with the channel/campaign that brought them, even if they browse
      a few pages first. Read by BookingForm.astro.
    -->
    <script is:inline>
      (() => {
        const KEY = 'lead-attribution';
        const params = new URLSearchParams(location.search);
        const keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
        const found = {};
        for (const key of keys) {
          const value = params.get(key);
          if (value) found[key] = value;
        }
        if (Object.keys(found).length && !localStorage.getItem(KEY)) {
          found.landing_page = location.pathname;
          localStorage.setItem(KEY, JSON.stringify(found));
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    {!minimal && <Header />}
    <main id="main">
      <slot />
    </main>
    {!minimal && <Footer />}
    {!minimal && <StickyCTA />}
    <ConsentPixel />

    <!-- Scroll-reveal: progressively enhances, respects reduced motion -->
    <script>
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -5% 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
